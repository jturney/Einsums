# needs_sphinx = '1.0'

# Make our custom EINSUMS extension visible.
sys.path.insert(0, os.path.abspath('.') + '/extensions')

# NOTE: the docs do NOT import the einsums runtime module. The entire C++ and
# Python API reference is generated statically from the headers by the
# apiary libclang tool (--emit-cpp-docs-json / --emit-docs-json), so the
# build needs only that tool, not a compiled ``_core`` extension. (There is no
# autodoc here either.)

# Add any Sphinx extension module names here, as strings. They can be
# extensions coming with Sphinx (named 'sphinx.ext.*') or your custom
# ones.
extensions = [
    'sphinxcontrib.bibtex',
    'sphinx.ext.autodoc',
    'sphinx.ext.doctest',
    'sphinx.ext.intersphinx',
    'sphinx.ext.todo',
    'sphinx.ext.coverage',
    'sphinx.ext.mathjax',
    'sphinx.ext.ifconfig',
    'sphinx.ext.viewcode',
    'sphinx_design',
    'sphinx-einsums',  # Custom Einsums roles
    'sphinx_copybutton',
]

# Doxygen + Breathe have been removed; the C++ API reference is generated by
# our own libclang tool (apiary --emit-cpp-docs-json + render_cpp_rst.py).
# ``module_source_lists`` keeps the per-lib list of header files the api loop
# enumerates (it used to double as module_source_lists).
module_source_lists = {}

einsums_source_dir = '@EINSUMS_SOURCE_DIR@'
einsums_libs_dir = einsums_source_dir + '/libs'
einsums_libs = {}
header_info = {}


def get_info_from_file(source):
    title = "None"
    header = "None"

    if os.path.exists(source):
        with open(source, 'r') as file:
            for line in file:
                if re.match(r"[\\@]page", line):
                    title = line.split(r"page", 1)[-1].strip()
                elif re.match(r"[\\@](header)?file", line):
                    header = line.split(r"file", 1)[-1].strip()

    return title, header


# Dictionary including the einsums headers with their base path
# needed to link to the einsums header files themselves.
# Links generated by docs/sphinx/extensions/sphinx-einsums.py
# The text in the rst file should be:
# :einsums-header:`base_path,file_name`
link_einsums_headers = {
}


def find_link_einsums_header(include_header):
    header_link = include_header
    for base_path, header_list in link_einsums_headers.items():
        if include_header in header_list:
            header_link = f":einsums-header:`{base_path},{include_header}`"
            break
        else:
            header_link = include_header
    return header_link


# Scan the libs directory for source files to be included in
# the documentation
file_regex = re.compile(r'.*\.(h|hpp)$')
# Libraries whose API reference is intentionally not generated. The
# EinsumsExperimental modules are left undocumented for now: wiring them
# through our libclang generator tripped a Sphinx cpp-domain crash
# (AssertionError 'parent_symbol'), and they're experimental.
_undocumented_libs = {'EinsumsExperimental'}
for lib_dir in os.listdir(einsums_libs_dir):
    # Only process subdirectories
    if not os.path.isdir(os.path.join(einsums_libs_dir, lib_dir)) or lib_dir == 'src':
        continue
    if lib_dir in _undocumented_libs:
        continue

    einsums_libs[lib_dir] = []

    full_lib_dir = os.path.join(einsums_libs_dir, lib_dir)
    module_source_lists[lib_dir] = (full_lib_dir, [])
    for subdir_full, dirs, files in os.walk(full_lib_dir):
        # strip the prefix of the directory...
        subdir = subdir_full[len(full_lib_dir) + 1:]

        # If we are in the root of the library dir, we add all
        # subdirectories as a new breathe project
        if len(subdir) == 0:
            for directory in dirs:
                einsums_libs[lib_dir].append(directory)
        # We are inside a module and need to add the files
        # to the breathe project
        else:
            # We only scan include subdir...
            if not '/include' in subdir:
                continue
            # ... but omit anything in detail directory
            if '/detail' in subdir:
                continue

            # strip the name of the module... the base path is already
            # set
            subdirs = subdir.split('/')
            module = subdirs[0]
            #subdir = '/'.join(subdirs[1:])
            # And now add all remaining files
            # which are headers or source files
            for f in files:
                if not file_regex.match(f) is None:
                    header_file_path = subdir_full + '/' + f
                    page_title, include_header = get_info_from_file(header_file_path)
                    module_source_lists[lib_dir][1].append(os.path.join(subdir, f))
                    include_prefix = 'include/'
                    include_index = header_file_path.find(include_prefix)
                    if include_index != -1:
                        header = header_file_path[include_index + len(include_prefix):]
                        header_info[header] = (page_title, include_header)

# Generate the rst files for the API documentation
api_refs = ''
api_ref_header = '''
.. 
    ----------------------------------------------------------------------------------------------
     Copyright (c) The Einsums Developers. All rights reserved.
     Licensed under the MIT License. See LICENSE.txt in the project root for license information.
    ----------------------------------------------------------------------------------------------

.. _modules_{0}_{1}_api:

-------------------------------------------------------------------------------
{0}
-------------------------------------------------------------------------------

See :ref:`modules_overview` for a list of names and headers that are part of the public
|einsums| API.
'''

api_header_file = '''
.. 
    ----------------------------------------------------------------------------------------------
     Copyright (c) The Einsums Developers. All rights reserved.
     Licensed under the MIT License. See LICENSE.txt in the project root for license information.
    ----------------------------------------------------------------------------------------------

.. _modules_{4}_{0}_api:

-------------------------------------------------------------------------------
{2}
-------------------------------------------------------------------------------

Defined in header {3}.

See :ref:`modules_overview` for a list of names and headers that are part of the public
|einsums| API.
'''

api_file = '''

.. toctree::
   :maxdepth: 1

'''

# Option 2: modules whose C++ API reference is generated by our own
# libclang tool (apiary --emit-cpp-docs-json + render_cpp_rst.py)
# instead of Breathe's autodoxygenfile. Configured from CMake.
cpp_docs_dir = r'@EINSUMS_CPP_DOCS_DIR@'
cpp_docs_modules = set('@EINSUMS_CPP_DOCS_MODULES@'.split())

# The cpp domain (under -n) cross-references every type identifier. Suppress
# the references that can never resolve to one of our own declarations:
# the C++ standard library, fundamental-ish aliases, and bare template
# parameters. Our own types resolve via the cpp:type/cpp:class directives
# the generator emits.
# Template-parameter names are never cpp cross-reference targets. The
# generator (gen_cpp_docs.py) writes out every one it saw across the wired
# modules; ignore exactly those, so we suppress params (T, Rank, MultiIndex,
# ...) without hiding genuine unresolved type references.
nitpick_ignore = []
import os as _os
_tparams_file = _os.path.join(cpp_docs_dir, 'template_params.txt')
if cpp_docs_dir and _os.path.exists(_tparams_file):
    with open(_tparams_file) as _tf:
        for _name in (_l.strip() for _l in _tf):
            if _name:
                nitpick_ignore.append(('cpp:identifier', _name))

for lib in einsums_libs.keys():
    for module in sorted(einsums_libs[lib]):
        
        module_sources = list(filter(lambda x: len(x.split(os.sep)) > 1 and module == x.split(os.sep)[0], module_source_lists[lib][1]))
        if len(module_sources) == 0:
            continue
        basedir = os.path.abspath('.') + '/libs/' + lib + '/' + module + '/api'
        if not os.path.exists(basedir):
            os.makedirs(basedir)
        with open(basedir + '/full_api.rst', 'w') as module_api_ref :
            module_api_ref.write(api_ref_header.format(lib, module))
            header_refs = ''
            header_names = set()
            for source in module_sources:
                header = source.split(os.sep)
                header = os.path.join(*header[header.index("include") + 1:])
                header_splitted = re.split('[/ .]', header)

                header_name = header_splitted[-2]
                # create a new, longer header name if current one already exists
                if header_name in header_names:
                    header_name = '{0}_{1}'.format(header_splitted[-3], header_name)
                header_names.add(header_name)

                # Get the info from the dictionary using the header file path
                page_title, include_header = header_info.get(header, ("None", "None"))
                if page_title == "None" or page_title == "" or page_title is None:
                    page_title = header
                if include_header == "None" or include_header == "" or include_header is None:
                    include_header = header

                gen_page = os.path.join(cpp_docs_dir, header.replace('/', '_').replace('.', '_') + '.rst')
                use_generated = ('{0}/{1}'.format(lib, module) in cpp_docs_modules) and os.path.exists(gen_page)
                with open(basedir + '/' + header_name + '.rst', 'w') as header_ref :
                    if use_generated:
                        # Option 2: the standard header (label + title, so the
                        # toctree entry keeps a title) followed by our
                        # libclang-generated cpp-domain body, replacing
                        # Breathe's autodoxygenfile.
                        #
                        # The body is written INLINE rather than via
                        # ``.. include::`` on purpose: a cpp:function declared
                        # inside an included file does NOT register in the
                        # global cpp domain index, so cross-page
                        # ``:cpp:func:`` references from user prose would
                        # dangle. Inlining declares it directly in this
                        # document, which registers globally.
                        prefix = api_header_file.format(
                            header, module, page_title, find_link_einsums_header(include_header), lib)
                        header_ref.write(prefix)
                        with open(gen_page) as _gen:
                            header_ref.write(_gen.read())
                    else:
                        # No generated page (the header documents no public
                        # entities). Write the header/title only — Doxygen +
                        # Breathe have been removed, so there is no
                        # autodoxygenfile fallback.
                        prefix = api_header_file.format(
                            header, module, page_title, find_link_einsums_header(include_header), lib)
                        header_ref.write(prefix)
                        header_ref.write('\nNo public API is documented in this header.\n')
                header_refs += '   /libs/' + lib + '/' + module + '/api/' + header_name + '.rst\n'
            module_api_ref.write(api_file)
            module_api_ref.write(header_refs)
        api_refs += '   /libs/' + lib + '/' + module + '/api/full_api.rst\n'

with open(os.path.abspath('.') + '/api/full_api.rst', 'w') as api_rst, open(f"{einsums_source_dir}/docs/sphinx/api/full_api.rst", "r") as lines :
    for line in lines:
        api_rst.write(line.format(api_refs))

numfig = True
