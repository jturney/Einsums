nitpick_ignore_regex = {(r"c(pp)?:identifier", r"size_t"),
    (r"c(pp)?:identifier", "ptrdiff_t"),
    (r"c(pp)?:identifier", r"u?int(8|16|32|64)_t"),
    (r"cpp:identifier", r"pybind11(::.*)?"),
    (r"cpp:identifier", r"_concept"),
    (r"cpp:identifier", r"HIP.*"),
    (r"cpp:identifier", r"hip.*_t"),
    (r"cpp:identifier", r"argparse.*"),
    (r"cpp:identifier", r".*detail.*"),
    (r"cpp:identifier", r"hipError.*"),
    (r"cpp:identifier", r"hipSuccess"),
    (r"cpp:identifier", r"hip.*Complex"),
    (r"cpp:identifier", r"dim3"),
    # Option 2 (our libclang-generated C++ reference): the C++ standard
    # library, a couple of external C aliases, and the dependent member
    # types of our template classes (``TensorView::Pointer``,
    # ``GeneralTensor::Reference``, ...) — never resolvable cross-reference
    # targets. (Template-parameter names are handled separately via the
    # exact ``nitpick_ignore`` list built from gen_cpp_docs output.)
    (r"cpp:identifier", r"std(::.*)?"),
    (r"cpp:identifier", r"(hid_t|herr_t|nullptr_t|char\d*_t|__fp16|__bf16)"),
    # Namespace-prefix components of qualified types in generated signatures.
    # Sphinx auto-cross-references every component of a qualified name
    # (``einsums::hashes::InsensitiveHash`` -> targets ``einsums``,
    # ``einsums::hashes``, ...); the namespace components themselves are never
    # documented as referenceable objects. End-anchored ($) and lowercase-only
    # so an actual type like ``einsums::ConfigMap`` is NOT suppressed. The
    # bare alternation covers sub-namespaces referenced without the
    # ``einsums::`` prefix (and the ``cg`` alias for ``einsums::compute_graph``).
    (r"cpp:identifier", r"einsums(::[a-z][a-z0-9_]*)*$"),
    (r"cpp:identifier",
     r"(compute_graph|packed_gemm|task_pool|linear_algebra|tensor_base|"
     r"string_util|fft|simd|hashes|blas|profile|print|comm|hptt|execution|cg)$"),
    # Dependent member types of our template classes (``flat_map::iterator``,
    # ``BufferAllocator::size_type``, ``TiledTensor::map_type``, ...): the
    # standard container/STL-style member aliases plus the project's own
    # (``map_type``, ``StoredType``). These live in template-instantiation
    # scope we don't document, so they can never be cross-reference targets.
    # The ``::``-qualifier is OPTIONAL ($-anchored): a member signature
    # rendered inside its own class scope relativizes ``flat_map::iterator``
    # down to the bare ``iterator``, so both spellings must be ignored.
    (r"cpp:identifier",
     r"(\w+::)?(Pointer|ConstPointer|Reference|ConstReference|Iterator|ConstIterator|"
     r"ReverseIterator|ConstReverseIterator|ValueType|StoredType|Vector|"
     r"pointer|const_pointer|reference|const_reference|iterator|const_iterator|"
     r"reverse_iterator|const_reverse_iterator|size_type|difference_type|"
     r"value_type|key_type|mapped_type|map_type|allocator_type|element_type)$"),
    # The over-generic leaves (``type``/``value``/``key``/``parameter`` and the
    # tensor-shape aliases) stay QUALIFIER-REQUIRED so bare common words are
    # not silently swallowed.
    (r"cpp:identifier", r"\w+::(Dim|Stride|Range|type|value|key|parameter)$"),
    # Bare ``value``/``key``/``parameter`` leak from generated Tensor signatures
    # where the class qualifier was relativized away — never documented targets.
    (r"cpp:identifier", r"(value|key|parameter)$"),
    # Template-id references (``TaskHandle<T>``, ``CVec<float>``,
    # ``RemoveComplexT<typename ...``): the declared target is the bare template
    # name, never the instantiation, so an angle-bracketed ref can't resolve.
    # (nitpick_ignore_regex is full-matched, so anchor both ends.)
    (r"cpp:identifier", r".*<.*"),
    # Internal / implementation-detail types used in public signatures but not
    # themselves documented (no doc comment → skipped by the docs filter), plus
    # private passkey types, internal constants and external (libc/GPU) names.
    (r"cpp:(identifier|class|func)",
     r"(PackingPlan|LogMessageQueue|ParseResult|BenchmarkResultQueue|InitParams|"
     r"PrivateConstructorStuff|RequestHandler|Rethrows|Operation|Consumer|Impl|"
     r"kNumCounterSlots|kMaxSymmetryRank|Indices|_th|"
     r"FILE|basic_string_view|hip_catch)$"),
    # Public symbols referenced from prose but not (yet) documented anywhere, so
    # there is no declaration to resolve against (optionally namespace-qualified).
    (r"cpp:(identifier|class|func)", r"(\w+::)*(subscript_tensor|EinsumDescriptor)$")
    }

suppress_warnings = [
    "duplicate_declaration.cpp"
]

